---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import StepsForm from '../components/StepsForm.astro';
import CityMap from '../components/CityMap.astro';
import config from '../data/config.json';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';

export async function getStaticPaths() {
  return communes.map((c) => ({
    params: { commune: c.slug },
    props: { commune: c },
  }));
}

const { commune } = Astro.props;
const localContent = generateCommuneContent(commune, 'copropriete');
const prices = getDynamicPrices(commune);
const nearbyCommunes = getSmartNearbyCommunes(commune.slug, communes);

const title = `Borne de Recharge en Copropriété à ${commune.nom} (${commune.codePostal}) | Droit à la prise`;
const description = `Vous résidez en appartement à ${commune.nom} (34) ? Guide complet sur le droit à la prise, les aides ADVENIR de 960 € et le raccordement parking.`;
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
  />

  <div class="container" style="padding-top: 40px; padding-bottom: 70px;">
    <Breadcrumb 
      links={[
        { label: 'Villes (34)', href: '/communes/' },
        { label: `Copropriété ${commune.nom}`, href: Astro.url.pathname }
      ]} 
    />

    <!-- Localized Hero Section -->
    <section class="local-hero" style="background: linear-gradient(135deg, var(--accent) 0%, #085a53 100%); color: white; border-radius: var(--radius-md); padding: 45px 35px; border: 1.5px solid var(--border-color); box-shadow: var(--shadow-md); margin-top: 30px; margin-bottom: 40px; position: relative; overflow: hidden;">
      <div style="position: absolute; top: -50px; right: -50px; font-size: 200px; opacity: 0.03; pointer-events: none;">🏢</div>
      <div style="max-width: 800px;">
        <span style="background-color: var(--secondary); color: white; padding: 5px 12px; border-radius: 50px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; margin-bottom: 15px;">🏢 Habitat Collectif &amp; Droit à la Prise (34)</span>
        <h1 style="font-size: 34px; font-family: var(--font-heading); font-weight: 800; line-height: 1.25; margin: 0 0 15px 0; color: white;">
          Borne de Recharge en Copropriété à {commune.nom} ({commune.codePostal})
        </h1>
        <p style="font-size: 16px; opacity: 0.95; line-height: 1.6; margin: 0;">
          {localContent.introParagraph}
        </p>
      </div>
    </section>

    <!-- Local Stats Bar -->
    <section class="local-stats-bar" style="background-color: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; margin-bottom: 40px;">
      <div style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px; text-align: center;">
        <div>
          <span style="display: block; font-family: var(--font-heading); font-weight: 800; font-size: 22px; color: var(--secondary);">960 € TTC</span>
          <span style="font-size: 12.5px; color: var(--primary); font-weight: 700;">Aide ADVENIR Max par place</span>
        </div>
        <div>
          <span style="display: block; font-family: var(--font-heading); font-weight: 800; font-size: 22px; color: var(--secondary);">50% de Prise en charge</span>
          <span style="font-size: 12.5px; color: var(--primary); font-weight: 700;">Subvention sur les travaux</span>
        </div>
        <div>
          <span style="display: block; font-family: var(--font-heading); font-weight: 800; font-size: 22px; color: var(--secondary);">3 Mois</span>
          <span style="font-size: 12.5px; color: var(--primary); font-weight: 700;">Délai de réponse légal syndic</span>
        </div>
        <div>
          <span style="display: block; font-family: var(--font-heading); font-weight: 800; font-size: 22px; color: var(--secondary);">{prices.copro.min}€ – {prices.copro.max}€</span>
          <span style="font-size: 12.5px; color: var(--primary); font-weight: 700;">Prix moyen posé (brut)</span>
        </div>
      </div>
    </section>

    <!-- Layout Grid -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 40px; align-items: start; margin-bottom: 50px;">
      
      <!-- Left Column: Localized Content -->
      <div style="display: flex; flex-direction: column; gap: 35px;">
        
        <!-- Block 1: Right to Plug -->
        <div style="background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
          <h2 style="font-size: 22px; color: var(--primary); font-family: var(--font-heading); font-weight: 700; margin-top: 0; margin-bottom: 15px;">📜 Comment fonctionne le droit à la prise à {commune.nom} ?</h2>
          <p style="font-size: 15px; color: var(--text); line-height: 1.6; margin: 0 0 15px 0;">
            {localContent.useCaseText}
          </p>
          <p style="font-size: 15px; color: var(--text); line-height: 1.6; margin: 0;">
            {localContent.localRegulation} {localContent.distanceMontpellierContext}
          </p>
        </div>

        <!-- Block 2: Infrastructure Collective -->
        <div style="background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
          <h2 style="font-size: 22px; color: var(--primary); font-family: var(--font-heading); font-weight: 700; margin-top: 0; margin-bottom: 15px;">🏢 Solutions de câblage collectif et Colonne Enedis</h2>
          <p style="font-size: 15px; color: var(--text); line-height: 1.6; margin: 0 0 15px 0;">
            {localContent.realEstateInsight} {localContent.profilCommuneInsight}
          </p>
          <blockquote style="margin: 20px 0 0; padding-left: 15px; border-left: 4px solid var(--accent); font-style: italic; color: var(--text-muted); font-size: 14px; line-height: 1.5;">
            {localContent.expertBlockquote}
          </blockquote>
        </div>

        <!-- Block 3: ADVENIR Subsidies Simulator -->
        <div style="background-color: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
          <h3 style="font-size: 19px; color: var(--primary); font-weight: bold; margin-top: 0; margin-bottom: 12px;">Simulateur Aide ADVENIR à {commune.nom}</h3>
          <p style="font-size: 14px; color: var(--text); line-height: 1.5; margin-bottom: 20px;">
            {localContent.ecoText}
          </p>
          <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px;">
            <div style="display: flex; flex-direction: column; gap: 8px; font-size: 13.5px;">
              <div style="display: flex; justify-content: space-between;"><span>Pose borne en copropriété (estimation) :</span><strong>{prices.copro.min} €</strong></div>
              <div style="display: flex; justify-content: space-between; color: var(--accent);"><span>Subvention ADVENIR (50% HT) :</span><strong>-{Math.round(prices.copro.min * 0.45)} €</strong></div>
              <div style="display: flex; justify-content: space-between; color: var(--accent);"><span>Crédit d'impôt national 2026 :</span><strong>-500 €</strong></div>
              <div style="display: flex; justify-content: space-between; font-weight: bold; color: var(--primary); border-top: 1px dashed var(--border-color); padding-top: 8px; margin-top: 5px;"><span>Reste à charge final estimé :</span><span>{Math.max(250, Math.round(prices.copro.min - (prices.copro.min * 0.45) - 500))} €</span></div>
            </div>
          </div>
        </div>

        <!-- Block 4: Technical Specs -->
        <div style="background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
          <h2 style="font-size: 22px; color: var(--primary); font-family: var(--font-heading); font-weight: 700; margin-top: 0; margin-bottom: 15px;">🛠️ Protections et Comptage individuel</h2>
          <p style="font-size: 14.5px; color: var(--text); line-height: 1.6; margin: 0 0 15px 0;">
            {localContent.specificiteElectrique} {localContent.communeDataInsight}
          </p>
          <p style="font-size: 14px; color: var(--text-muted); margin: 0;">
            Chaque point de charge est configuré avec un sous-compteur MID ou Linky dédié pour relever les index et rembourser le syndic de copropriété sans litige.
          </p>
        </div>

        <!-- Map section -->
        <CityMap cityName={commune.nom} zip={commune.codePostal} />

      </div>

      <!-- Right Column: Interactive form -->
      <aside style="position: sticky; top: 20px;">
        <div id="devis" style="background-color: var(--card-bg); border: 2.5px solid var(--border-color); border-radius: var(--radius-md); padding: 25px 20px; box-shadow: var(--shadow-md);">
          <h3 style="font-size: 19px; color: var(--primary); font-family: var(--font-heading); font-weight: 800; margin-top: 0; margin-bottom: 5px; text-align: center;">🏢 Devis Copropriété</h3>
          <p style="font-size: 13px; color: var(--text-muted); text-align: center; margin-top: 0; margin-bottom: 20px; line-height: 1.4;">
            Raccordement place de parking en immeuble collectif à {commune.nom}.
          </p>
          <StepsForm initialZip={commune.codePostal} />
        </div>
      </aside>

    </div>

    <!-- Local FAQ -->
    <section class="local-faq" style="background-color: var(--bg); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 40px; margin-bottom: 50px;">
      <h2 style="font-size: 28px; color: var(--primary); font-family: var(--font-heading); font-weight: 800; text-align: center; margin-top: 0; margin-bottom: 30px;">FAQ Copropriété à {commune.nom}</h2>
      <div style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px;">
        {localContent.faqItems.map((item) => (
          <details class="faq-details">
            <summary>{item.question}</summary>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Geographic Interlinking Section -->
    <section class="nearby-links-section" style="border-top: 1px solid var(--border-color); padding-top: 40px;">
      <h3 style="font-size: 20px; color: var(--primary); font-family: var(--font-heading); font-weight: 800; margin-bottom: 20px; text-align: center;">🏢 Bornes Copropriété dans les communes proches :</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
        {nearbyCommunes.map((c) => (
          <a 
            href={`/borne-recharge-copropriete-${c.slug}/`} 
            style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 12px 15px; font-size: 14px; font-weight: 600; color: var(--primary); text-decoration: none; text-align: center; transition: var(--transition);"
          >
            {c.nom} ({c.codePostal})
          </a>
        ))}
      </div>
    </section>

  </div>
</Layout>

<style>
  @media (max-width: 992px) {
    div {
      grid-template-columns: 1fr !important;
      gap: 30px !important;
    }
    aside {
      position: static !important;
    }
  }
  .nearby-links-section a:hover {
    border-color: var(--secondary) !important;
    background-color: var(--primary-light) !important;
    color: var(--secondary) !important;
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
</style>
