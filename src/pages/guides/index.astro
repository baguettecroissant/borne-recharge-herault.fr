---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import config from '../../data/config.json';
import { getCollection } from 'astro:content';

const title = `Guides & Conseils Borne de Recharge Hérault (34) | Électricien IRVE`;
const description = `Découvrez tous nos guides pratiques, conseils techniques, tarifs et aides financières pour l'installation de votre borne de recharge (Wallbox) dans le 34.`;

const guides = await getCollection('guides');
// Sort by publishDate desc
const sortedGuides = guides.sort((a, b) => {
  const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
  const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
  return dateB - dateA;
});
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
  />

  <div class="container" style="padding-top: 40px; padding-bottom: 70px;">
    <Breadcrumb links={[{ label: 'Guides', href: '/guides/' }]} />

    <div style="margin-top: 30px; margin-bottom: 50px; text-align: center;">
      <h1 style="font-size: 38px; color: var(--primary); font-family: var(--font-heading); font-weight: 800;">📚 Guides &amp; Conseils d'Experts IRVE</h1>
      <p style="color: var(--text-muted); font-size: 17px; max-width: 700px; margin: 15px auto 0; line-height: 1.6;">
        Toutes les informations indispensables pour réussir votre installation de borne de recharge ou prise renforcée dans l'Hérault. Réglementation ZFE, subventions, solutions solaires et copropriété.
      </p>
    </div>

    <!-- Guides Grid -->
    <div class="guides-index-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 30px;">
      {sortedGuides.map((guide) => (
        <article style="background: var(--card-bg); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; transition: var(--transition);">
          <div style="aspect-ratio: 16/9; overflow: hidden; background-color: var(--primary-light);">
            <img 
              src={guide.data.image} 
              alt={guide.data.title}
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;"
              loading="lazy"
            />
          </div>
          <div style="padding: 24px; display: flex; flex-direction: column; flex-grow: 1; gap: 12px;">
            <span style="font-size: 12px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.5px;">🌻 Guide Pratique</span>
            <h2 style="font-size: 19px; color: var(--primary); font-family: var(--font-heading); font-weight: 700; margin: 0; line-height: 1.35;">
              <a href={`/guides/${guide.id}/`} style="color: inherit; text-decoration: none; transition: var(--transition);">
                {guide.data.title}
              </a>
            </h2>
            <p style="font-size: 14px; color: var(--text-muted); line-height: 1.5; margin: 0; flex-grow: 1;">
              {guide.data.description}
            </p>
            <div style="border-top: 1px solid var(--primary-light); padding-top: 15px; display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
              <span style="font-size: 12px; color: var(--text-muted);">Par {guide.data.author}</span>
              <a href={`/guides/${guide.id}/`} style="font-weight: 700; font-size: 13.5px; color: var(--secondary); text-decoration: none; display: flex; align-items: center; gap: 4px;">
                Lire la suite &rarr;
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA Section -->
    <div style="margin-top: 70px; background: linear-gradient(135deg, var(--primary) 0%, #431407 100%); border-radius: var(--radius-md); padding: 50px 40px; text-align: center; color: white; position: relative; overflow: hidden; border: 1.5px solid var(--border-color); box-shadow: var(--shadow-md);">
      <div style="position: absolute; top: -50px; right: -50px; font-size: 180px; opacity: 0.05; pointer-events: none; transform: rotate(15deg);">🌻</div>
      <h2 style="font-size: 28px; font-family: var(--font-heading); font-weight: 800; margin-bottom: 15px; color: white;">Votre projet de borne de recharge dans l'Hérault ?</h2>
      <p style="max-width: 600px; margin: 0 auto 30px; font-size: 16px; opacity: 0.9; line-height: 1.5;">
        Obtenez 3 devis comparatifs gratuits de la part d'électriciens certifiés IRVE proches de chez vous (Montpellier, Béziers, Sète, Agde...).
      </p>
      <a href="/devis/" class="contact-btn" style="background-color: var(--accent); color: white; border: none; padding: 14px 36px; border-radius: 50px; font-weight: 700; font-size: 16px; text-decoration: none; display: inline-block; box-shadow: 0 4px 15px rgba(13, 148, 136, 0.4); transition: var(--transition);">
        📋 Obtenir mes Devis Gratuits
      </a>
    </div>
  </div>
</Layout>

<style>
  article:hover {
    transform: translateY(-5px);
    border-color: var(--secondary) !important;
    box-shadow: var(--shadow-md) !important;
  }
  article:hover img {
    transform: scale(1.05);
  }
</style>
